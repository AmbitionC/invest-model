# invest-model 环境变量示例
# 复制为 .env 后按需填写：  cp .env.example .env
# .env 已在 .gitignore 中忽略，不会入库。

# ──────────────────────────────────────────────────────────────
# 数据库后端
# ──────────────────────────────────────────────────────────────
# 方式一（推荐本地/验证）：直接给一个完整 SQLAlchemy URL，优先级高于下方 MySQL_* 拼接。
#   SQLite 文件库（无需外部服务），相对路径基于项目根：
# INVEST_DB_URL=sqlite:///./data/local.db
#   也可在命令行用 --db 覆盖，例如：
#   python scripts/run_pipeline.py --mode all --db sqlite:///./data/local.db

# 方式二（生产 MySQL / 阿里云 RDS）：未设置 INVEST_DB_URL 且未传 --db 时，
# 由下列变量拼出 mysql+pymysql URL。
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=invest

# ──────────────────────────────────────────────────────────────
# 数据源 Tushare（仅 --mode update 拉真实数据时需要；本地合成验证不需要）
# ──────────────────────────────────────────────────────────────
# Tushare token（官网或所购镜像套餐给的 token；生产用 GitHub Actions / FC Secret）：
TUSHARE_TOKEN=
# 数据服务基地址（含 VIP 接口）：填所购镜像地址，结尾按其文档要求（gyzcloud 需带 /api）。
# 生产以 Secret 为唯一真源；config.yaml 已不再硬编码，留空则走官方 HTTPS。
# TUSHARE_HTTP_URL=https://ts.gyzcloud.top/api
