# ⚠️ 本文件已升级为「实际生效配置」的说明副本 ——
# 真实资源配置在 fe-journey-faas 仓库的 s.yaml（resources: investLiveWatch /
# investScheduler），push master 即由其 CI（deploy-invest-scheduler job）自动：
#   checkout 本仓库 → bash faas/package.sh ./invest-dist → s deploy 两个 FC 函数。
# 这里只保留最小骨架供参考/手动部署；完整触发器与环境变量清单见 fe-journey-faas。
#
# 两个函数、一份代码包（faas/package.sh 产物），与 fe-journey 完全解耦：
#
# resources:
#   investLiveWatch:                 # 盯盘：512MB / 120s
#     component: fc3
#     props:
#       region: cn-hangzhou
#       functionName: invest-live-watch
#       runtime: python3.10
#       handler: faas/scheduler_handler.handler
#       code: ./invest-dist
#       triggers:
#         - triggerType: timer
#           triggerConfig: { cronExpression: '0 0/3 1-7 ? * MON-FRI',  # UTC
#                            enable: true, payload: 'live_watch' }
#
#   investScheduler:                 # 快照提醒/ETF入库/日更+计划/周度重建+复盘：4GB / 3h
#     component: fc3
#     props:
#       functionName: invest-scheduler
#       runtime: python3.10
#       handler: faas/scheduler_handler.handler
#       code: ./invest-dist
#       triggers:                    # payload = faas/jobs.py 的 job 名（cron 均为 UTC）
#         - { cronExpression: '0 20 7 ? * MON-FRI', payload: 'snapshot_remind' }       # 15:20
#         - { cronExpression: '0 50 8 ? * MON-FRI', payload: 'ingest_etf' }            # 16:50
#         - { cronExpression: '0 0 9 ? * MON-FRI',  payload: 'daily_update_plan' }     # 17:00
#         - { cronExpression: '0 0 10 ? * SAT',     payload: 'weekly_rebuild_review' } # 周六18:00
#
# 环境变量（在 fe-journey-faas 的 GitHub Secrets/Variables 配置，随部署注入）：
#   INVEST_DB_URL（或 DB_HOST/DB_USER/DB_PASS+INVEST_DB_NAME）
#   TUSHARE_TOKEN  TUSHARE_HTTP_URL
#   INVEST_GH_PAT（fine-grained PAT：仅本仓库 Issues RW → 函数内 GITHUB_TOKEN）
#   可选：ACCOUNT_CASH  PLAN_ARGS  LIVE_WATCH_MENTION
#   只读文件系统适配（s.yaml 已内置）：INVEST_LOG_DIR=/tmp/logs
#                                     INVEST_RESULTS_DIR=/tmp/invest-results
