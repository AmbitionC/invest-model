# 追加到 fe-journey-faas 的 s.yaml（Serverless Devs v3 / fc3 组件）——
# 新建独立函数 invest-live-watch，与 fe-journey 服务端函数完全解耦：
#   独立代码包 / 独立环境变量 / 独立内存超时 / 独立触发器，
#   仅共用阿里云账号、地域，以及（若 RDS 走内网）同一套 VPC 配置。
# 部署互不影响：fe-journey 发版不会动本函数，反之亦然。
#
# 代码来源：invest-model 仓库执行 `bash faas/package.sh` 产出
#   dist/faas-build/（目录）或 dist/invest-live-watch.zip（上传用）。

resources:
  invest-live-watch:
    component: fc3
    props:
      region: cn-hangzhou               # ← 改成与你 RDS/fe-journey 相同地域
      functionName: invest-live-watch
      description: A股盘中盯盘（无状态定时扫描，预警推 GitHub issue→邮件）
      runtime: python3.10
      handler: faas/live_watch_handler.handler
      memorySize: 512
      timeout: 120                       # ETF 均线取数偶发重试，给足余量
      code: ../invest-model/dist/faas-build   # ← package.sh 的产物路径，按实际调整
      environmentVariables:
        INVEST_DB_URL: ${env(INVEST_DB_URL)}       # mysql+pymysql://...
        TUSHARE_TOKEN: ${env(TUSHARE_TOKEN)}
        TUSHARE_HTTP_URL: ${env(TUSHARE_HTTP_URL)} # 如 https://minitick.top/
        GITHUB_TOKEN: ${env(INVEST_GH_PAT)}        # fine-grained PAT：仅 invest-model Issues RW
        GITHUB_REPOSITORY: AmbitionC/invest-model
        DIGEST_WINDOW: "20"                        # 买点/提示摘要窗口（分钟）
        ONCE_STEP: "3"                             # 与下方定时器间隔一致
      # RDS 走内网（推荐，与 fe-journey 服务端同配置即可）：
      # vpcConfig:
      #   vpcId: vpc-xxxx
      #   vSwitchIds: [vsw-xxxx]
      #   securityGroupId: sg-xxxx
      # RDS 走公网：需在 RDS 白名单放行 FC 出口 IP（或函数配 NAT 固定 IP）
      triggers:
        - triggerName: market-hours
          triggerType: timer
          qualifier: LATEST
          triggerConfig:
            # FC cron 为 UTC：每 3 分钟，01:00-07:59 UTC = 北京 09:00-15:59 工作日。
            # 盘前/午休/节假日由脚本守卫毫秒级退出，空转成本可忽略。
            cronExpression: "0 0/3 1-7 ? * MON-FRI"
            enable: true
